# Keep the audio/ prefix in the uploaded object keys, for example:
#   audio/rain.mp3
#   audio/jazz/cafe/01-jazz-cafe.mp3
#
# Examples:
# VITE_AUDIO_BASE_URL=https://pub-xxxxxxxx.r2.dev/
# VITE_AUDIO_BASE_URL=https://assets.example.com/
